# ─── Required for build / SEO ────────────────────────────────────────────────
# Canonical site URL used in sitemap, hreflang, OpenGraph, and JSON-LD.
# Must match the live domain exactly — no trailing slash.
# Local dev fallback: http://localhost:3010 (set automatically by src/lib/env.ts)
NEXT_PUBLIC_SITE_URL=https://pureva.fr

# ─── Required for order emails (Resend) ──────────────────────────────────────
# Obtain API key from resend.com — use a key scoped to the sending domain only.
# If these vars are missing, /api/order returns a safe 500 and logs a warning.
RESEND_API_KEY=

# Must use a domain verified in Resend (SPF + DKIM configured).
# Example: commandes@pureva.fr
FROM_EMAIL=commandes@pureva.fr

# Internal inbox that receives order notification emails.
BUSINESS_EMAIL=hello@pureva.fr

# ─── Required for WhatsApp CTAs ──────────────────────────────────────────────
# International format, no + or spaces. Example: 33600000000 (French number)
# If absent, all WhatsApp CTA links are hidden (href="#", no external links shown).
NEXT_PUBLIC_WHATSAPP_NUMBER=

# ─── Optional — rate limiting (Upstash Redis) ────────────────────────────────
# When absent, rate limiting is silently disabled (no error, no crash).
# Provides a 5-requests-per-10-minutes limit per IP on POST /api/order.
# Free Upstash tier is sufficient. See: upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Legal content gate ───────────────────────────────────────────────────────
# Set to "true" only after legal pages have been reviewed by a qualified professional.
# When absent or not "true": legal pages render with a warning banner + noindex metadata.
# When "true": warning banner hidden, legal pages become indexable.
LEGAL_CONTENT_CONFIRMED=
